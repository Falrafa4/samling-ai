APP_NAME=Samling API
DEBUG=True
SECRET_KEY=ini_secret_key_yang_harus_diubah_bebas
DATABASE_URL=sqlite:///samling.db
MODEL_PATH=app/ai/models
UPLOAD_FOLDER=app/uploads

# ==============================================================================
# CONFIGURATION PENJADWALAN OTOMATIS (AI BACKGROUND SCHEDULER)
# Menggunakan format standar Crontab: * * * * * (menit jam hari_bulan bulan hari_minggu)
# Contoh: Untuk menjalankan setiap 5 menit, gunakan "*/5 * * * *"
# ==============================================================================

# 1. Pipeline Harian (Pengumpulan Data TPS & Forecasting Volume Sampah)
# Tugas: Mengumpulkan data sensor kapasitas terupdate dan menjalankan peramalan volume sampah.
# Default: "0 7 * * *" (Setiap hari pukul 07:00 pagi)
SCHEDULER_DAILY_PIPELINE_CRON="0 7 * * *"

# 2. Rekomendasi Rute Navigasi Supir (VRP OR-Tools)
# Tugas: Menghitung rute optimal bagi supir berdasarkan TPS yang berstatus CRITICAL/WARNING.
# Default: "30 7 * * *" (Setiap hari pukul 07:30 pagi)
SCHEDULER_ROUTE_RECOMMENDATION_CRON="30 7 * * *"

# 3. Retraining Model Machine Learning
# Tugas: Melatih ulang model Gradient Boosting Regressor dengan data baru agar akurasi tetap optimal.
# Default: "0 0 * * 1" (Setiap hari Senin pukul 00:00 dini hari)
SCHEDULER_WEEKLY_RETRAIN_CRON="0 0 * * 1"